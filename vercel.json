{
  "framework": null,
  "buildCommand": "",
  "outputDirectory": "",
  "rewrites": [
    { "source": "/api/analyze", "destination": "/api/analyze" },
    { "source": "/api/news", "destination": "/api/news" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "functions": {
    "api/analyze.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/news.js": {
      "maxDuration": 10,
      "memory": 256
    }
  }
}
